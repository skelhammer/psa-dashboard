# Python
__pycache__/
*.py[cod]
*.pyo
*.egg
*.egg-info/
dist/
build/
.venv/
venv/
*.whl

# Database
**/*.db
**/*.db-journal
**/*.db-wal
**/*.db-shm

# Config (contains secrets)
config.yaml

# Vault master key and session signing key (auto-generated per install,
# never share or commit). Losing these means losing access to stored secrets.
**/.vault_master_key
**/.session_signing_key

# Migration backup files: these contain plaintext credentials taken out
# of config.yaml the first time the encrypted vault was bootstrapped.
*.pre-secrets.bak

# Audit log file (if file-logging is enabled in vault/audit.py)
logs/

# Node
node_modules/
frontend/dist/
frontend/.vite/
frontend/tsconfig.tsbuildinfo

# Environment
.env
.env.*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Claude Code
.claude/

# Logs
*.log
npm-debug.log*
pip-log.txt

# Testing / Coverage
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.tox/
